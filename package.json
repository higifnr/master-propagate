{
  "name": "master-propagate-extension",
  "displayName": "Master Propagate",
  "publisher": "higifnr",
  "repository": { "type": "git", "url": "https://github.com/higifnr/master-propagate" },
  "license": "MIT",
  "description": "Propagate changes from a master file to child files on save",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "masterPropagate.setAsMaster",
        "title": "Master Propagate: Set as Master"
      },
      {
        "command": "masterPropagate.createChild",
        "title": "Master Propagate: Create Child from Master"
      },
      {
        "command": "masterPropagate.addExistingAsChild",
        "title": "Master Propagate: Add Existing File as Child"
      },
      {
        "command": "masterPropagate.unlink",
        "title": "Master Propagate: Unlink File"
      },
      {
        "command": "masterPropagate.showRelationships",
        "title": "Master Propagate: Show Relationships"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "masterPropagate.setAsMaster",
          "group": "masterPropagate@1"
        },
        {
          "command": "masterPropagate.createChild",
          "group": "masterPropagate@2"
        },
        {
          "command": "masterPropagate.addExistingAsChild",
          "group": "masterPropagate@3"
        },
        {
          "command": "masterPropagate.unlink",
          "group": "masterPropagate@4"
        }
      ]
    },
    "configuration": {
      "title": "Master Propagate",
      "properties": {
        "masterPropagate.childSnapshotBehavior": {
          "type": "string",
          "enum": [
            "alwaysTrackMaster",
            "snapshotAtCreation"
          ],
          "default": "alwaysTrackMaster",
          "description": "alwaysTrackMaster: diffs master's previous vs current state and patches children. snapshotAtCreation: diffs master's creation-time snapshot vs current state."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/diff": "^5.0.9",
    "diff": "^5.1.0",
    "node-diff3": "^3.2.0"
  }
}